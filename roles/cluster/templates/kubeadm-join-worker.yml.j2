---
apiVersion: kubeadm.k8s.io/v1beta4
kind: JoinConfiguration
discovery:
  bootstrapToken:
{% if multi_master %}
    apiServerEndpoint: "{{ control_plane_endpoint }}"
{% else %}
    apiServerEndpoint: "{{ hostvars[k8s_init_node]['ansible_host'] }}:{{ k8s_api_port }}"
{% endif %}
    token: "{{ kubeadm_token | default('<generated-by-kubeadm-init>') }}"
    caCertHashes:
      - "sha256:{{ kubeadm_ca_cert_hash | default('<generated-by-kubeadm-init>') }}"
nodeRegistration:
  criSocket: unix:///var/run/containerd/containerd.sock
  name: "{{ inventory_hostname }}"
  kubeletExtraArgs:
    - name: "node-ip"
      value: "{{ ansible_host }}"
