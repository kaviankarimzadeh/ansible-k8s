---
apiVersion: kubeadm.k8s.io/v1beta4
kind: InitConfiguration
localAPIEndpoint:
  advertiseAddress: "{{ ansible_host }}"
  bindPort: {{ k8s_api_port }}
nodeRegistration:
  criSocket: unix:///var/run/containerd/containerd.sock
  name: "{{ inventory_hostname }}"
  kubeletExtraArgs:
    - name: "node-ip"
      value: "{{ ansible_host }}"
---
apiVersion: kubeadm.k8s.io/v1beta4
kind: ClusterConfiguration
kubernetesVersion: "v{{ kubernetes_version }}"
clusterName: kubernetes
{% if multi_master %}
controlPlaneEndpoint: "{{ control_plane_endpoint }}"
{% else %}
controlPlaneEndpoint: "{{ ansible_host }}:{{ k8s_api_port }}"
{% endif %}
networking:
  podSubnet: "{{ pod_network_cidr }}"
  serviceSubnet: "{{ service_network_cidr }}"
  dnsDomain: "{{ cluster_domain }}"
{% if (etcd_extra_args | default({})) %}
etcd:
  local:
    extraArgs:
{% for key, value in etcd_extra_args.items() %}
      - name: "{{ key }}"
        value: "{{ value }}"
{% endfor %}
{% endif %}
apiServer:
  certSANs:
    - "{{ k8s_api_vip }}"
{% for host in groups['k8s_masters'] %}
    - "{{ hostvars[host]['ansible_host'] }}"
    - "{{ host }}"
{% endfor %}
    - "127.0.0.1"
    - "localhost"
{% if (kube_apiserver_extra_args | default({})) %}
  extraArgs:
{% for key, value in kube_apiserver_extra_args.items() %}
    - name: "{{ key }}"
      value: "{{ value }}"
{% endfor %}
{% endif %}
{% if (kube_controller_extra_args | default({})) %}
controllerManager:
  extraArgs:
{% for key, value in kube_controller_extra_args.items() %}
    - name: "{{ key }}"
      value: "{{ value }}"
{% endfor %}
{% endif %}
{% if (kube_scheduler_extra_args | default({})) %}
scheduler:
  extraArgs:
{% for key, value in kube_scheduler_extra_args.items() %}
    - name: "{{ key }}"
      value: "{{ value }}"
{% endfor %}
{% endif %}
proxy:
  disabled: {{ kube_proxy_disabled | lower }}
---
apiVersion: kubelet.config.k8s.io/v1beta1
kind: KubeletConfiguration
{% for key, value in kubelet_config.items() %}
{{ key }}: {{ value }}
{% endfor %}
